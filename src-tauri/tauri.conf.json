{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tavari Client",
  "version": "1.0.8",
  "identifier": "com.tavari.client",
  "build": {
    "frontendDist": "../tauri-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Tavari Client",
        "width": 1320,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Tavari Client",
        "url": "splash.html",
        "width": 540,
        "height": 320,
        "minWidth": 540,
        "minHeight": 320,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset: ipc: http://ipc.localhost",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: data: blob: https://mauricioespinosa84-dotcom.github.io https://mc-heads.net",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' asset:",
        "object-src": "'none'",
        "frame-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBQ0MzOTVDMDhEQ0I4OEEKUldTS3VOd0lYRG5NU2s5R1F1b0Q2a0k1ZHA1UERjRVhSM3lmNVdGMG5LNUMzdkhLckR6cUFCT2wK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
